# API
PORT=3000
API_PORT=3000
WEB_PORT=4321

# Web (SSR → API)
# Préférer 127.0.0.1 à localhost (évite le conflit IPv6 ::1 avec d’autres apps)
API_URL=http://127.0.0.1:3000
PUBLIC_API_URL=http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Persistance données (survit à docker compose down / rebuild)
#
# VPS — /projets/@data est PARTAGÉ entre projets. Ne pas écrire à la racine
# de @data (déjà : ludolist/, mysql/, …). Uniquement le sous-dossier dédié :
#
#   /projets/
#     @data/
#       ludolist/          ← autre projet — NE PAS TOUCHER
#       mysql/             ← autre projet — NE PAS TOUCHER
#       wheretosurvive/    ← CE projet uniquement
#         postgres/
#         redis/
#         etl/
#     whereToSurvive/
#
# Local (défaut) : ./.data/wheretosurvive/...
# ---------------------------------------------------------------------------
# DATA_ROOT=/projets/@data
DATA_ROOT=./.data
# Ou chemins explicites (toujours sous …/wheretosurvive/) :
# POSTGRES_DATA_DIR=/projets/@data/wheretosurvive/postgres
# REDIS_DATA_DIR=/projets/@data/wheretosurvive/redis
# ETL_DATA_DIR=/projets/@data/wheretosurvive/etl

# Postgres (Docker)
POSTGRES_USER=wheretosurvive
POSTGRES_PASSWORD=wheretosurvive
POSTGRES_DB=wheretosurvive
POSTGRES_PORT=5432
DATABASE_URL=postgresql://wheretosurvive:wheretosurvive@localhost:5432/wheretosurvive

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Données — DEV : échantillon (100 communes métropole les plus peuplées)
# Import : nombre, ou "all" / "0" pour toute la métropole (prod)
COMMUNE_LIMIT=100

# ETL DRIAS
# ETL_LIMIT=100             # plafond de nouveaux fetchs (dev)
# ETL_HORIZON=2050          # 2030 | 2050 | all
DRIAS_ENSEMBLE=1
DRIAS_SKIP_EXISTING=1
# DRIAS_FORCE=0
# DRIAS_CHECKPOINT=./data/drias-checkpoint-{horizon}.jsonl
